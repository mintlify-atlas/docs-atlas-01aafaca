  "keyFeatures": [
    "JWT-based password reset flow with secure token hashing",
    "Appointment lookup by patient ID with doctor and service details",
    "Automated daily email reminders for upcoming appointments via Resend",
    "Bcrypt password hashing with Laravel-compatible $2y$ format",
    "MySQL/Sequelize ORM with multi-role user model (admin, doctor, receptionist, patient)",
    "CORS, Helmet, and environment-based security configuration"
  ],
  "publicApiSurface": [
    "POST /api/auth/forgot-password",
    "POST /api/auth/reset-password",
    "GET /api/citas/proxima/:id_paciente",
